{
  "name": "nexusos",
  "private": true,
  "version": "2.0.6",
  "description": "The Sovereign Neural Operating System — Locally Inferenced, Globally Distributed.",
  "author": "Philippe-Antoine Robert",
  "main": "electron-main.cjs",
  "type": "commonjs",
  "scripts": {
    "dev": "node -e \"const { execSync } = require('child_process'); try { execSync('npx kill-port 3000', { stdio: 'inherit' }); } catch (e) {}\" && npx vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run build && electron-builder",
    "test": "npx tsx kernel/tests/runTests.ts",
    "e2e": "vite build && node e2e/appSmoke.mjs"
  },
  "dependencies": {
    "@google/genai": "^1.34.0",
    "@wllama/wllama": "^2.4.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.4.11",
    "isomorphic-git": "^1.38.5",
    "lucide-react": "^0.562.0",
    "puter": "^1.0.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-rnd": "^10.5.2",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.23",
    "axios": "^1.16.1",
    "concurrently": "^10.0.3",
    "dotenv": "^17.3.1",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.13",
    "puppeteer": "^24.39.1",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.8.2",
    "vite": "^8.0.16",
    "wait-on": "^9.0.4"
  }
}
